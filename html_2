<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🕌 Masjid Raya Depok - Digital Islamic Center</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: linear-gradient(135deg, #0f3460 0%, #1e3c72 50%, #2a5298 100%);
            --secondary: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
            --accent: linear-gradient(135deg, #00d4aa 0%, #00a651 100%);
            --glass: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.2);
            --shadow: 0 25px 45px rgba(0,0,0,0.1);
            --shadow-hover: 0 35px 60px rgba(0,0,0,0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
            background: #0a0a0a;
            color: white;
        }

        /* Particle Background */
        #particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at 20% 50%, rgba(120,119,198,0.3) 0%, transparent 50%),
                        radial-gradient(circle at 80% 20%, rgba(255,119,198,0.3) 0%, transparent 50%),
                        radial-gradient(circle at 40% 80%, rgba(120,219,255,0.3) 0%, transparent 50%);
        }

        /* Header */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1rem 5%;
            backdrop-filter: blur(20px);
            background: var(--glass);
            border-bottom: 1px solid var(--glass-border);
            z-index: 1000;
            transition: all 0.3s ease;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
        }

        .logo {
            font-family: 'Amiri', serif;
            font-size: 2rem;
            background: var(--secondary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
            cursor: pointer;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 3rem;
        }

        .nav-links a {
            color: white;
            text-decoration: none;
            font-weight: 500;
            position: relative;
            transition: all 0.3s ease;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--secondary);
            transition: width 0.3s ease;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
        }

        .hero-content {
            max-width: 800px;
            padding: 0 2rem;
            animation: fadeInUp 1.5s ease;
        }

        .hero h1 {
            font-family: 'Amiri', serif;
            font-size: clamp(3rem, 8vw, 6rem);
            background: var(--secondary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1.5rem;
            text-shadow: 0 0 30px rgba(255,215,0,0.5);
        }

        .hero p {
            font-size: 1.4rem;
            margin-bottom: 3rem;
            opacity: 0.9;
            line-height: 1.8;
        }

        .cta-buttons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn {
            padding: 1.2rem 3rem;
            border: none;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1.1rem;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
        }

        .btn-primary {
            background: var(--secondary);
            color: #1e3c72;
            box-shadow: var(--shadow);
        }

        .btn-secondary {
            background: var(--glass);
            border: 2px solid var(--glass-border);
            color: white;
        }

        .btn:hover {
            transform: translateY(-8px) scale(1.05);
            box-shadow: var(--shadow-hover);
        }

        /* Floating Mosque 3D */
        .floating-mosque {
            position: absolute;
            top: 20%;
            right: 10%;
            width: 300px;
            height: 400px;
            background: linear-gradient(145deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
            border-radius: 30px;
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            animation: float 6s ease-in-out infinite;
            box-shadow: var(--shadow);
        }

        .dome {
            width: 120px;
            height: 120px;
            background: var(--secondary);
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            position: absolute;
            top: -60px;
            left: 50%;
            transform: translateX(-50%);
            box-shadow: 0 20px 40px rgba(255,215,0,0.3);
            animation: glow 2s ease-in-out infinite alternate;
        }

        .minaret {
            width: 25px;
            height: 150px;
            background: var(--accent);
            border-radius: 15px 15px 0 0;
            position: absolute;
            top: 50px;
            box-shadow: 0 15px 30px rgba(0,212,170,0.3);
        }

        .minaret.left { left: 20px; }
        .minaret.right { right: 20px; }

        /* Sections */
        section {
            padding: 8rem 5%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-title {
            text-align: center;
            font-size: 3.5rem;
            font-family: 'Amiri', serif;
            background: var(--secondary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 4rem;
            position: relative;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -20px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: var(--secondary);
            border-radius: 2px;
            box-shadow: 0 0 20px rgba(255,215,0,0.5);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 4rem;
        }

        .stat-card {
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 25px;
            padding: 2.5rem 2rem;
            text-align: center;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .stat-card:hover::before {
            left: 100%;
        }

        .stat-card:hover {
            transform: translateY(-15px) scale(1.02);
            border-color: var(--secondary);
            box-shadow: var(--shadow-hover);
        }

        .stat-icon {
            font-size: 3.5rem;
            background: var(--secondary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 700;
            background: var(--secondary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        /* Prayer Times */
        .prayer-container {
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 30px;
            padding: 3rem;
            margin-top: 4rem;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .prayer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 1.5rem;
            text-align: center;
        }

        .prayer-time {
            background: rgba(255,255,255,0.05);
            padding: 1.5rem 1rem;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.1);
            transition: all 0.3s ease;
        }

        .prayer-time:hover {
            background: rgba(255,215,0,0.1);
            border-color: var(--secondary);
            transform: scale(1.05);
        }

        .prayer-name {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--secondary);
        }

        .prayer-clock {
            font-size: 1.5rem;
            font-weight: 700;
        }

        /* Footer */
        footer {
            background: var(--primary);
            padding: 4rem 5% 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin: 2rem 0;
        }

        .social-link {
            width: 60px;
            height: 60px;
            background: var(--glass);
            border: 1px solid var(--glass-border);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .social-link:hover {
            background: var(--secondary);
            transform: translateY(-10px) rotate(360deg);
            box-shadow: 0 15px 30px rgba(255,215,0,0.4);
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotateX(0deg); }
            50% { transform: translateY(-20px) rotateX(2deg); }
        }

        @keyframes glow {
            from { box-shadow: 0 0 20px rgba(255,215,0,0.5); }
            to { box-shadow: 0 0 40px rgba(255,215,0,0.8); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }
            
            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }
            
            .floating-mosque {
                display: none;
            }
            
            section {
                padding: 4rem 2rem;
            }
        }

        /* Scroll Progress */
        .scroll-progress {
            position: fixed;
            top: 0;
            left: 0;
            height: 4px;
            background: var(--secondary);
            z-index: 1001;
            transition: width 0.1s ease;
        }
    </style>
</head>
<body>
    <!-- Scroll Progress -->
    <div class="scroll-progress" id="scrollProgress"></div>

    <!-- Particle Background -->
    <canvas id="particles"></canvas>

    <!-- Header -->
    <header>
        <nav>
            <div class="logo" onclick="scrollToTop()">
                🕌 <span>Masjid Raya Depok</span>
            </div>
            <ul class="nav-links">
                <li><a href="#home">Beranda</a></li>
                <li><a href="#stats">Statistik</a></li>
                <li><a href="#prayer">Jadwal Sholat</a></li>
                <li><a href="#gallery">Galeri</a></li>
                <li><a href="#contact">Kontak</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero -->
    <section id="home" class="hero">
        <div class="floating-mosque">
            <div class="dome"></div>
            <div class="minaret left"></div>
            <div class="minaret right"></div>
        </div>
        <div class="hero-content">
            <h1>Masjid Raya Depok</h1>
            <p>🕌 Pusat Ibadah Modern Terbesar di Kota Depok | Kapasitas 15.000 Jamaah | Arsitektur Karya Ridwan Kamil</p>
            <div class="cta-buttons">
                <a href="#stats" class="btn btn-primary">
                    <i class="fas fa-chart-line"></i> Lihat Statistik
                </a>
                <a href="#prayer" class="btn btn-secondary">
                    <i class="fas fa-clock"></i> Jadwal Sholat
                </a>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section id="stats">
        <h2 class="section-title">📊 Statistik Masjid</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-number">15,000</div>
                <div class="stat-label">Kapasitas Jamaah</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-ruler-combined"></i>
                </div>
                <div class="stat-number">22,000m²</div>
                <div class="stat-label">Luas Bangunan</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-layer-group"></i>
                </div>
                <div class="stat-number">5</div>
                <div class="stat-label>Lantai</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-number">24/7</div>
                <div class="stat-label>Terbuka</div>
            </div>
        </div>
    </section>

    <!-- Prayer Times -->
    <section id="prayer">
        <h2 class="section-title">⏰ Jadwal Sholat</h2>
        <div class="prayer-container">
            <div class="prayer-grid">
                <div class="prayer-time">
                    <div class="prayer-name">Subuh</div>
                    <div class="prayer-clock">04:45</div>
                </div>
                <div class="prayer-time">
                    <div class="prayer-name">Dzuhur</div>
                    <div class="prayer-clock">11:55</div>
                </div>
                <div class="prayer-time">
                    <div class="prayer-name">Ashar</div>
                    <div class="prayer-clock">15:15</div>
                </div>
                <div class="prayer-time">
                    <div class="prayer-name">Maghrib</div>
                    <div class="prayer-clock">17:55</div>
